# ================================================
# GOLEM AGENT v3.0 — Zero-Cost AI Agent Config
# ================================================

# ── Gemini Flash API (中介層，極低消耗) ───────────
# 免費取得：https://aistudio.google.com/app/apikey
# 🧬 可留空，將完全使用 Gemini Web（訪客模式）
GEMINI_API_KEY=your_gemini_api_key_here

# ── 路由模式設定 ─────────────────────────────────
# true = 強制所有請求走 Gemini Web（完全不使用 API）
# false = 智能路由（根據複雜度自動切換）
FORCE_WEB_MODE=false

# ── 智能路由設定 ────────────────────────────────
# 複雜度閾值 0~1，超過此值走網頁版 Gemini（完全免費）
# （當 FORCE_WEB_MODE=false 時生效）
COMPLEXITY_THRESHOLD=0.6
ROUTER_TOKEN_LIMIT=800

# ── Telegram Bot 設定 ────────────────────────────
# 取得 Token: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 允許使用的用戶 ID（留空=所有人可用，多個用逗號分隔）
TELEGRAM_ALLOWED_USERS=

# ── 瀏覽器設定 ──────────────────────────────────
# headed = 有視窗 | headless = 背景靜默
# 瀏覽器設定
# 優先使用電腦已安裝的 Google Chrome（更真實，避免被偵測）
# 設成 false 改用 Playwright 內建的 Chromium
USE_SYSTEM_CHROME=true

BROWSER_MODE=headed
BROWSER_SESSION_PATH=./browser/session.json
GEMINI_WEB_URL=https://gemini.google.com
BROWSER_RESPONSE_TIMEOUT=60000

# 分頁池最大數量（被阻擋時輪換，建議 3~8）
BROWSER_MAX_TABS=5

# ── Agent 設定 ──────────────────────────────────
AGENT_NAME=Golem
AGENT_WORKSPACE=./projects
AGENT_LOG_LEVEL=info

# ── 記憶設定 ────────────────────────────────────
MEMORY_MAX_SHORT_TERM=20
MEMORY_MAX_LONG_TERM=500

# ── 自主模式設定 ────────────────────────────────
AUTO_MODE_MAX_ITERATIONS=50
AUTO_MODE_REFLECTION_INTERVAL=5
