# ================================================
# Gemini Web AI Agent (Telegram Bot 版本)
# ================================================

# ── Telegram Bot 設定 ───────────────────────────
# 從 @BotFather 取得：https://t.me/BotFather
# 1. 在 Telegram 搜尋 @BotFather
# 2. 傳送 /newbot 建立新機器人
# 3. 依照指示輸入機器人名稱和 username
# 4. 複製取得的 Token 填入下方
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── 允許使用的用戶（可選）────────────────────────
# 填入 Telegram Chat ID，多個用戶用逗號分隔
# 留空表示允許所有人使用
# 獲取 Chat ID: 傳送訊息給 @userinfobot，它會回覆您的 ID
TELEGRAM_ALLOWED_USERS=

# ── Gemini Flash API（選用，用於 AI 偵測 selector）────
# 免費取得：https://aistudio.google.com/app/apikey
# 注意：簡化版主要使用固定 selector，此 Key 為選用
GEMINI_API_KEY=

# ── 瀏覽器設定 ──────────────────────────────────
# headed = 有視窗（可見瀏覽器運作）
# headless = 背景模式（無視窗）
BROWSER_MODE=headed

# Gemini 網址
GEMINI_WEB_URL=https://gemini.google.com

# 回應超時時間（毫秒）
BROWSER_RESPONSE_TIMEOUT=90000

# ── 其他設定 ────────────────────────────────────
# 日誌層級：debug | info | warn | error
LOG_LEVEL=info
